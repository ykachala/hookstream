{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Hookstream webhook delivery engine observability dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(hookstream_deliveries_total{status=\"delivered\"}[5m])) by (tenant_id)",
          "legendFormat": "delivered — tenant={{tenant_id}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(hookstream_deliveries_total{status=\"failed\"}[5m])) by (tenant_id)",
          "legendFormat": "failed — tenant={{tenant_id}}",
          "refId": "B"
        },
        {
          "expr": "sum(rate(hookstream_deliveries_total{status=\"dead_letter\"}[5m])) by (tenant_id)",
          "legendFormat": "dead_letter — tenant={{tenant_id}}",
          "refId": "C"
        },
        {
          "expr": "sum(rate(hookstream_deliveries_total{status=\"circuit_open\"}[5m])) by (tenant_id)",
          "legendFormat": "circuit_open — tenant={{tenant_id}}",
          "refId": "D"
        }
      ],
      "title": "Delivery Rate by Status",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(hookstream_delivery_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(hookstream_delivery_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(hookstream_delivery_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Delivery Duration (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "hookstream_queue_depth",
          "legendFormat": "queue depth",
          "refId": "A"
        }
      ],
      "title": "Queue Depth Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "cellOptions": { "type": "color-background" } },
          "mappings": [
            { "options": { "0": { "text": "CLOSED" } }, "type": "value" },
            { "options": { "1": { "text": "OPEN" } }, "type": "value" },
            { "options": { "2": { "text": "HALF_OPEN" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 },
              { "color": "yellow", "value": 2 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": []
      },
      "targets": [
        {
          "expr": "hookstream_circuit_breaker_state",
          "legendFormat": "{{subscriber_id}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Circuit Breaker State per Subscriber",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "valueLabel": "subscriber_id" }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["hookstream", "webhooks"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Hookstream",
  "uid": "hookstream",
  "version": 1
}
